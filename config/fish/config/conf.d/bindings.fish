# Key bindings

# Shortcuts for jumping to beginning/end of buffer
bind ctrl-home beginning-of-buffer
bind ctrl-end end-of-buffer

# Word movement and deletion
bind alt-left backward-word
bind alt-right forward-word
bind alt-backspace backward-kill-word
bind alt-delete kill-word

# Token movement and deletion
bind alt-shift-left backward-token
bind alt-shift-right forward-token
bind alt-shift-backspace backward-kill-token
bind alt-shift-delete kill-token
